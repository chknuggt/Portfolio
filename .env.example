# -------------------------------------------------------
# Docker Compose
# -------------------------------------------------------
UID=1000
GID=1000
APP_PORT=8080
VITE_PORT=5173

# -------------------------------------------------------
# Laravel
# -------------------------------------------------------
APP_NAME=Portfolio
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

# -------------------------------------------------------
# Database
# -------------------------------------------------------
DB_CONNECTION=mariadb
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=portfolio
DB_USERNAME=portfolio
DB_PASSWORD=secret
DB_ROOT_PASSWORD=rootsecret

# -------------------------------------------------------
# Redis
# -------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# -------------------------------------------------------
# Cache & Session
# -------------------------------------------------------
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=database

# -------------------------------------------------------
# Mail
# -------------------------------------------------------
MAIL_MAILER=log
